# Firebase project configuration
FIREBASE_PROJECT_ID=replace-with-your-project-id

# Flutter Firebase runtime options (pass as --dart-define)
FIREBASE_API_KEY=replace-with-api-key
FIREBASE_APP_ID=replace-with-app-id
FIREBASE_MESSAGING_SENDER_ID=replace-with-sender-id
FIREBASE_AUTH_DOMAIN=replace-with-auth-domain
FIREBASE_STORAGE_BUCKET=replace-with-storage-bucket

# Use local emulator for Functions routing in Flutter
FIREBASE_USE_EMULATOR=true
