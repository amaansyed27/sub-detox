# Firebase project configuration
FIREBASE_PROJECT_ID=replace-with-your-project-id

# Flutter Firebase runtime options (pass as --dart-define)
FIREBASE_API_KEY=replace-with-api-key
FIREBASE_APP_ID=replace-with-app-id
FIREBASE_MESSAGING_SENDER_ID=replace-with-sender-id
FIREBASE_AUTH_DOMAIN=replace-with-auth-domain
FIREBASE_STORAGE_BUCKET=replace-with-storage-bucket

# Flutter backend routing mode:
# functions-emulator | functions-cloud | fastapi-local | fastapi-cloud
BACKEND_MODE=fastapi-local

# Optional for fastapi-cloud mode
CLOUD_RUN_URL=https://replace-with-cloud-run-service-url

# Optional for custom direct base URL routing
BACKEND_BASE_URL=

# Local FastAPI mode settings for emulator/device testing
FASTAPI_LOCAL_PORT=8000
LOCAL_API_HOST=

# Keep Firebase auth emulator toggle for Flutter auth path
FIREBASE_USE_EMULATOR=true

# FastAPI runtime settings
USE_FIRESTORE_EMULATOR=false
FIRESTORE_EMULATOR_HOST=127.0.0.1:8081
AUTH_BYPASS_ENABLED=false
AUTH_BYPASS_HEADER=X-Dev-User
PUBLIC_BASE_URL=http://127.0.0.1:8000
WEBHOOK_RETRY_ATTEMPTS=3
WEBHOOK_TIMEOUT_SECONDS=4

# Optional Gemini enrichment (rules engine remains primary)
GEMINI_ANALYSIS_ENABLED=false
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
GEMINI_TIMEOUT_SECONDS=8
GEMINI_FALLBACK_ON_ERROR=true
